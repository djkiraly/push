# Core
PUSH_PORT=7531
PUSH_HOST=127.0.0.1
# 64 hex chars — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PUSH_MASTER_KEY=
DATABASE_URL=file:./data/push.db
NODE_ENV=development
# Required for Instagram photo posts (Meta needs a reachable image_url).
# e.g. https://push.<tunnel-domain>.example or your ngrok URL.
PUSH_PUBLIC_URL=

# Facebook / Instagram (single Meta app, login via FB)
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:7531/api/oauth/meta/callback

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:7531/api/oauth/tiktok/callback

# YouTube (Google Cloud project)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:7531/api/oauth/google/callback

# AI (optional — can be set via UI Settings instead)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
