{
  "name": "push",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first social media scheduler for RocketCore.AI operator",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "next build && tsc -p tsconfig.server.json",
    "start": "cross-env NODE_ENV=production node dist/server.js",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "service:install": "tsx service/install.ts",
    "service:uninstall": "tsx service/uninstall.ts",
    "service:start": "net start \"PushScheduler\"",
    "service:stop": "net stop \"PushScheduler\""
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@tanstack/react-query": "^5.59.0",
    "better-sqlite3": "^11.5.0",
    "argon2": "^0.41.1",
    "chokidar": "^4.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.5",
    "fluent-ffmpeg": "^2.1.3",
    "googleapis": "^144.0.0",
    "jose": "^5.9.6",
    "lucide-react": "^0.460.0",
    "next": "^16.0.0",
    "node-windows": "^1.0.0-beta.8",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "pino-roll": "^2.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.33.5",
    "tailwind-merge": "^2.5.5",
    "undici": "^7.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.9.0",
    "@types/node-windows": "^0.1.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "eslint": "^9.15.0",
    "eslint-config-next": "^16.0.0",
    "postcss": "^8.4.49",
    "prisma": "^7.0.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.5"
  }
}
